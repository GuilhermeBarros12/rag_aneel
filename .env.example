# ============================================================
# CONFIGURAÇÕES DO PROJETO RAG ANEEL
# ============================================================
# Copie este arquivo para .env e preencha com suas chaves reais:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
#
# O .env NUNCA deve ser commitado no repositório (já está no .gitignore)
# ============================================================

# ── LLM primário: Gemini (Google AI Studio) ──────────────────
# Crie sua chave GRATUITA em: https://aistudio.google.com/app/apikey
# Basta ter uma conta Google — leva menos de 2 minutos
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── LLM fallback: Groq (usado se o Gemini atingir o limite) ──
# Crie sua chave GRATUITA em: https://console.groq.com
GROQ_API_KEY=sua_chave_groq_aqui

# ── Vectorstore no Hugging Face Hub ──────────────────────────
# Repositório com o índice ChromaDB pré-construído
# O pipeline.py baixa automaticamente na primeira execução
HF_REPO_ID=seu-usuario-hf/aneel-vectorstore

# Token de acesso ao Hugging Face (necessário para upload e repos privados)
# Crie em: https://huggingface.co/settings/tokens (tipo: Write)
HF_TOKEN=seu_token_hf_aqui

# ── Configurações do retriever ────────────────────────────────
# Quantos chunks retornar por query (padrão: 5)
TOP_K=5